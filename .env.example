# 複製本檔為 .env 並填入實際值
# admin 白名單：以外部論壇帳號指定管理員，格式 server:username，逗號分隔。
# server 為 heavensbride 或 tcgm；避免兩站同名衝突。
# 例：ADMIN_USERS=heavensbride:alice,tcgm:bob
ADMIN_USERS=heavensbride:change-me

# 簽 token 用的隨機字串（請改成隨機長字串）
SECRET_KEY=please-change-to-a-long-random-secret

# 公開網址（產生文章連結、widget deep-link 用）
PUBLIC_BASE_URL=http://localhost:8000

# 選用：資料庫路徑（預設 backend/data/hs.db）
# HS_DB_PATH=backend/data/hs.db
