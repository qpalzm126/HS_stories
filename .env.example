# 複製本檔為 .env 並填入實際值
# 後台「AI 產草稿」用（Google AI Studio 免費金鑰 https://aistudio.google.com/apikey）
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxx

# 後台登入密碼（發佈文章用）
ADMIN_PASSWORD=change-me

# 簽 token 用的隨機字串（請改成隨機長字串）
SECRET_KEY=please-change-to-a-long-random-secret

# 公開網址（產生文章連結、widget deep-link 用）
PUBLIC_BASE_URL=http://localhost:8000

# 選用：模型覆寫（預設 gemini-flash-latest；後台每次產草稿前也可即時改選）
# HS_DRAFT_MAP_MODEL=gemini-flash-latest
# HS_DRAFT_MODEL=gemini-pro-latest

# 選用：資料庫路徑（預設 backend/data/hs.db）
# HS_DB_PATH=backend/data/hs.db
