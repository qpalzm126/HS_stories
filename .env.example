# 複製本檔為 .env 並填入實際值
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 後台登入密碼（發佈文章用）
ADMIN_PASSWORD=change-me

# 簽 token 用的隨機字串（請改成隨機長字串）
SECRET_KEY=please-change-to-a-long-random-secret

# 公開網址（產生文章連結、widget deep-link 用）
PUBLIC_BASE_URL=http://localhost:8000

# 選用：模型覆寫
# HS_DRAFT_MAP_MODEL=claude-haiku-4-5-20251001
# HS_DRAFT_MODEL=claude-opus-4-8

# 選用：資料庫路徑（預設 backend/data/hs.db）
# HS_DB_PATH=backend/data/hs.db
